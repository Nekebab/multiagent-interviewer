# Required
# Mistral AI API key. https://console.mistral.ai/
MISTRAL_API_KEY=your-mistral-key-here

# Optional
# Tavily search API for the InternetSearch tool.
# https://tavily.com/
TAVILY_API_KEY=

# Path to expert knowledge CSV (column: 'text'). Leave default if unused.
# EXPERT_CSV_PATH=data/expert_knowledge.csv

# Path to manager (HR) knowledge CSV. Leave default if unused.
# MANAGER_CSV_PATH=data/manager_knowledge.csv

# Tunables (uncomment to override defaults)
# LLM_MODEL=mistral-large-latest
# LLM_TEMPERATURE=0.7
# CHUNK_SIZE=500
# CHUNK_OVERLAP=100
# MAX_TURNS=10
# LOG_LEVEL=INFO
